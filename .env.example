# Frontend env (CRA).
# Copy this file to .env.local and edit.

# Backend API base URL (no trailing slash)
REACT_APP_API_URL=https://nanmame.com/api/

# Public site URL (used in some SEO meta tags)
REACT_APP_SITE_URL=https://nanmame.com

# WhatsApp number — international format, no '+', no spaces
REACT_APP_WHATSAPP=971547566000

# Dev port (CRA picks this up via PORT in .env.local)
PORT=3001
